{
    "appService.defaultWebAppToDeploy": "",
    "appService.deploySubpath": "zide-backend-auth-service",
    "python.defaultInterpreterPath": "${workspaceFolder}/zide-backend-jobs-service/.venv/bin/python",
    "files.watcherExclude": {
        "**/node_modules/**": true
    },
    "search.exclude": {
        "**/node_modules": true
    },
    "files.associations": {
        "**/.github/workflows/*.yml": "yaml",
        "**/.github/workflows/*.yaml": "yaml"
    },
    "problems.exclude": {
        "**/.github/workflows/*.yml": true,
        "**/.github/workflows/*.yaml": true
    },
    "github-actions.workflows.pinned.refresh.enabled": false
}